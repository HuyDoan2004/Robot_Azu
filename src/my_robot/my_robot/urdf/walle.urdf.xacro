<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="walle">

  <!-- ====== Args ====== -->
  <xacro:arg name="total_height" default="0.3"/>  <!-- mét, đỉnh cao nhất -->
  <xacro:arg name="body_mesh"    default="package://my_robot/meshes/walle_body.dae"/>
  <xacro:arg name="body_scale"   default="0.5"/>
  <xacro:arg name="head_forward" default="0.06"/>

  <xacro:arg name="lower_by" default="0.14"/>  <!-- hạ xuống 2cm, đổi tuỳ mắt -->
  <xacro:property name="z_body" value="${0.12 - float(xacro.arg('lower_by'))}"/>

  <!-- Ép kiểu float khi dùng trong biểu thức -->
  <xacro:property name="pivot_z" value="${float(xacro.arg('total_height')) - 0.10}"/>

  <!-- ====== Base ====== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 ${z_body}" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.25" ixy="0" ixz="0" iyy="0.25" iyz="0" izz="0.30"/>
    </inertial>
    <visual>
      <!-- QUAY mesh sang phải 90° quanh trục Z -->
      <origin xyz="0 0 ${z_body}" rpy="0 0 -1.57079632679"/>
      <geometry>
        <mesh filename="${xacro.arg('body_mesh')}"
              scale="${float(xacro.arg('body_scale'))} ${float(xacro.arg('body_scale'))} ${float(xacro.arg('body_scale'))}"/>
      </geometry>
    </visual>
    <collision>
      <!-- cũng xoay collision cho khớp -->
      <origin xyz="0 0 ${z_body}" rpy="0 0 -1.57079632679"/>
      <geometry><box size="0.30 0.30 0.30"/></geometry>
    </collision>
  </link>

  <!-- ====== Head pan/tilt ====== -->
  <link name="head_yaw_link"/>
  <joint name="head_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="head_yaw_link"/>
    <origin xyz="0 0 ${pivot_z}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="5.0" velocity="2.0"/>
  </joint>

  <link name="head_pitch_link"/>
  <joint name="head_pitch" type="revolute">
    <parent link="head_yaw_link"/>
    <child link="head_pitch_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.2" upper="0.9" effort="5.0" velocity="2.0"/>
  </joint>

  <!-- ====== Camera body ====== -->
  <link name="camera_link">
    <visual>
      <origin xyz="${float(xacro.arg('head_forward'))} 0 0" rpy="0 0 0"/>
      <geometry><box size="0.10 0.06 0.05"/></geometry>
    </visual>
    <collision>
      <origin xyz="${float(xacro.arg('head_forward'))} 0 0" rpy="0 0 0"/>
      <geometry><box size="0.10 0.06 0.05"/></geometry>
    </collision>
  </link>
  <joint name="camera_fixed" type="fixed">
    <parent link="head_pitch_link"/>
    <child link="camera_link"/>
    <origin xyz="${float(xacro.arg('head_forward'))} 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ====== RealSense frames (REP-103) ====== -->
  <link name="camera_color_frame"/>
  <joint name="camera_color_frame_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_color_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_color_optical_frame"/>
  <joint name="camera_color_optical_joint" type="fixed">
    <parent link="camera_color_frame"/>
    <child link="camera_color_optical_frame"/>
    <!-- x right, y down, z forward -->
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <link name="camera_depth_frame"/>
  <joint name="camera_depth_frame_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_depth_optical_frame"/>
  <joint name="camera_depth_optical_joint" type="fixed">
    <parent link="camera_depth_frame"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <!-- ====== (THÊM) IMU frame (gắn trên camera) ====== -->
  <link name="imu_link"/>
  <joint name="camera_to_imu" type="fixed">
    <parent link="camera_link"/>
    <child  link="imu_link"/>
    <!-- Nếu IMU không đúng tâm, chỉnh xyz tại đây -->
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ====== LiDAR ở đỉnh cao nhất ====== -->
  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.04" length="0.06"/></geometry></visual>
    <collision><geometry><cylinder radius="0.04" length="0.06"/></geometry></collision>
  </link>
  <joint name="lidar_mount" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${float(xacro.arg('total_height'))}" rpy="0 0 0"/>
  </joint>

</robot>
